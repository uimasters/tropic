# ========================================
# 🌴 TROPICO - Environment Configuration
# ========================================

# AI APIs
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tropico
REDIS_URL=redis://localhost:6379

# Server Configuration
NODE_ENV=development
PORT=3000
API_PORT=5000
LOG_LEVEL=debug

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Email Service
MAILCHIMP_API_KEY=your-mailchimp-key
KLAVIYO_API_KEY=your-klaviyo-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Third-party Integrations
STRIPE_API_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

INSTAGRAM_ACCESS_TOKEN=your-instagram-token
TIKTOK_CLIENT_ID=your-tiktok-client-id
TWITTER_API_KEY=your-twitter-api-key

# AWS Configuration (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=tropico-generated-files
AWS_S3_REGION=us-east-1

# URLs
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEPLOYMENT_URL=https://tropico.ai

# File Storage
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=./uploads

# Monitoring & Analytics
SENTRY_DSN=your-sentry-dsn
POSTHOG_API_KEY=your-posthog-key
NEW_RELIC_LICENSE_KEY=your-newrelic-key

# Feature Flags
FEATURE_AI_IMAGES=true
FEATURE_COMPETITOR_CLONE=true
FEATURE_WHITE_LABEL=false
FEATURE_ADVANCED_ANALYTICS=false

# Limits & Quotas
MAX_WEBSITES_PER_MONTH=5
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_SECONDS=600
FILE_UPLOAD_MAX_SIZE_MB=50

# Cache
CACHE_TTL_SECONDS=3600
CACHE_PROVIDER=redis

# Email Templates
EMAIL_FROM=noreply@tropico.ai
EMAIL_FROM_NAME=Tropico AI

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
CORS_ORIGIN=http://localhost:3000

# Debug Mode
DEBUG=false
VERBOSE_LOGGING=false
